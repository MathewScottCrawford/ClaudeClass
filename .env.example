# ============================================================
#  EMAIL AI PIPELINE — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env — only commit this .env.example file.
# ============================================================

# --- n8n Core -----------------------------------------------
# Change this to a strong random string for security
N8N_ENCRYPTION_KEY=replace_with_random_32char_string

# The URL n8n is accessible at (used for webhooks)
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Optional: set your timezone for scheduling nodes
GENERIC_TIMEZONE=America/Chicago

# --- n8n Auth (basic auth for the UI) -----------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace_with_strong_password

# --- Ollama -------------------------------------------------
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL_FAST=phi4-mini
OLLAMA_MODEL_SMART=llama3.1

# --- LangGraph Agent Service --------------------------------
AGENT_SERVICE_URL=http://host.docker.internal:8000
AGENT_SERVICE_API_KEY=replace_with_random_string

# --- Gmail OAuth (filled after Google Cloud Console setup) --
# These are managed via n8n credentials UI, not env vars.
# Document your OAuth Client ID here for reference only.
# GMAIL_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com

# --- Yahoo Mail (IMAP) --------------------------------------
# These are managed via n8n credentials UI.
# YAHOO_EMAIL=your_address@yahoo.com
# YAHOO_APP_PASSWORD=your_app_password  (not your login password)

# --- Output destinations (optional) -------------------------
# GOOGLE_SHEETS_SPREADSHEET_ID=your_sheet_id
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
